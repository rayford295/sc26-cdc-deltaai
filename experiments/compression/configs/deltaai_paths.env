# Default DeltaAI paths for the SC26 compression experiment suite.
#
# Usage:
#   source experiments/compression/configs/deltaai_paths.env
#
# Override any value at submit time, for example:
#   N_IMAGES=100 sbatch experiments/compression/slurm/01_baseline_resolution_batch.sbatch

BASE="${BASE:-/projects/bfod/${USER}/cdc-deltaai}"
REPO_DIR="${REPO_DIR:-${BASE}/code}"
IMG_DIR="${IMG_DIR:-${BASE}/data/imgs}"
WEIGHT_DIR="${WEIGHT_DIR:-${BASE}/weights/x_param}"
RUN_STAMP="${RUN_STAMP:-$(date +%Y%m%d_%H%M%S)}"
OUT_BASE="${OUT_BASE:-${BASE}/output/sc26_compression/${RUN_STAMP}}"

LPIPS_WEIGHT_BASELINE="${LPIPS_WEIGHT_BASELINE:-0.9}"
N_DENOISE_STEP="${N_DENOISE_STEP:-65}"
GAMMA="${GAMMA:-0.8}"
N_IMAGES="${N_IMAGES:-8}"
START_INDEX="${START_INDEX:-0}"
SAVE_VISUAL_LIMIT="${SAVE_VISUAL_LIMIT:-2}"

# Main pretrained checkpoint used in prior reconstruction/compression tests.
CKPT_BASELINE="${CKPT_BASELINE:-${WEIGHT_DIR}/image-l2-use_weight5-vimeo-d64-t8193-b0.2048-x-cosine-01-float32-aux0.9lpips_2.pt}"

# Candidate checkpoint sweep. The repo has no x-param runtime compression-level
# parameter, so low/medium/high should be assigned from measured BPP after this
# sweep rather than assumed from the filename alone.
CKPT_B00032="${CKPT_B00032:-${WEIGHT_DIR}/image-l2-use_weight5-vimeo-d64-t8193-b0.0032-x-cosine-01-float32-aux0.0_2.pt}"
CKPT_B00064="${CKPT_B00064:-${WEIGHT_DIR}/image-l2-use_weight5-vimeo-d64-t8193-b0.0064-x-cosine-01-float32-aux0.0_2.pt}"
CKPT_B00128="${CKPT_B00128:-${WEIGHT_DIR}/image-l2-use_weight5-vimeo-d64-t8193-b0.0128-x-cosine-01-float32-aux0.0_2.pt}"
CKPT_B00512="${CKPT_B00512:-${WEIGHT_DIR}/image-l2-use_weight5-vimeo-d64-t8193-b0.0512-x-cosine-01-float32-aux0.9lpips_2.pt}"
CKPT_B01024="${CKPT_B01024:-${WEIGHT_DIR}/image-l2-use_weight5-vimeo-d64-t8193-b0.1024-x-cosine-01-float32-aux0.9lpips_2.pt}"
CKPT_B02048="${CKPT_B02048:-${WEIGHT_DIR}/image-l2-use_weight5-vimeo-d64-t8193-b0.2048-x-cosine-01-float32-aux0.9lpips_2.pt}"

LPIPS_B00032=0.0
LPIPS_B00064=0.0
LPIPS_B00128=0.0
LPIPS_B00512=0.9
LPIPS_B01024=0.9
LPIPS_B02048=0.9
